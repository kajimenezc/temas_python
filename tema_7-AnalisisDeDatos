# ============================================================================
# ANÁLISIS DE TEMPERATURAS EN TRES CIUDADES
# ============================================================================
print("\n" + "="*70)
print("ANÁLISIS ESTADÍSTICO DE TEMPERATURAS EN TRES CIUDADES")
print("="*70)

# Crear datos de temperaturas diarias (3 ciudades x 30 días)
# Temperaturas en grados Celsius para un mes
np.random.seed(42)  # Para reproducibilidad
temperaturas = np.array([
    np.random.uniform(15, 28, 30),  # Ciudad 1: temperaturas de 15 a 28°C
    np.random.uniform(10, 25, 30),  # Ciudad 2: temperaturas de 10 a 25°C
    np.random.uniform(20, 35, 30),  # Ciudad 3: temperaturas de 20 a 35°C
])

# Redondear a 1 decimal para mejor legibilidad
temperaturas = np.round(temperaturas, 1)

ciudades = ['Ciudad A', 'Ciudad B', 'Ciudad C']

print("\nDatos de temperaturas (primeros 10 días):")
for i, ciudad in enumerate(ciudades):
    print(f"{ciudad}: {temperaturas[i, :10]}")

print("\n" + "-"*70)
print("ESTADÍSTICAS POR CIUDAD")
print("-"*70)

# Diccionarios para almacenar resultados
media_ciudades = {}
temp_max_ciudades = {}
temp_min_ciudades = {}
mediana_ciudades = {}
Q1_ciudades = {}
Q3_ciudades = {}
IQR_ciudades = {}
outliers_ciudades = {}

# Analizar cada ciudad
for i, ciudad in enumerate(ciudades):
    temps = temperaturas[i, :]
    
    # 1. Calcular la temperatura media para cada ciudad
    media = np.mean(temps)
    media_ciudades[ciudad] = media
    print(f"\n{ciudad}:")
    print(f"  Temperatura media: {media:.2f}°C")
    
    # 2. Identificar la temperatura máxima y mínima
    temp_max = np.max(temps)
    temp_min = np.min(temps)
    temp_max_ciudades[ciudad] = temp_max
    temp_min_ciudades[ciudad] = temp_min
    print(f"  Temperatura máxima: {temp_max:.2f}°C")
    print(f"  Temperatura mínima: {temp_min:.2f}°C")
    print(f"  Rango: {temp_max - temp_min:.2f}°C")
    
    # 3. Calcular la mediana de temperaturas
    mediana = np.median(temps)
    mediana_ciudades[ciudad] = mediana
    print(f"  Mediana: {mediana:.2f}°C")
    
    # 4. Calcular los cuartiles y el rango intercuartílico (IQR)
    Q1 = np.percentile(temps, 25)
    Q3 = np.percentile(temps, 75)
    IQR = Q3 - Q1
    
    Q1_ciudades[ciudad] = Q1
    Q3_ciudades[ciudad] = Q3
    IQR_ciudades[ciudad] = IQR
    
    print(f"  Q1 (25er percentil): {Q1:.2f}°C")
    print(f"  Q3 (75er percentil): {Q3:.2f}°C")
    print(f"  Rango Intercuartílico (IQR): {IQR:.2f}°C")
    
    # 5. Identificar outliers
    limite_inferior = Q1 - 1.5 * IQR
    limite_superior = Q3 + 1.5 * IQR
    
    outliers = temps[(temps < limite_inferior) | (temps > limite_superior)]
    dias_outliers = np.where((temps < limite_inferior) | (temps > limite_superior))[0] + 1
    
    outliers_ciudades[ciudad] = {
        'valores': outliers,
        'dias': dias_outliers,
        'limite_inferior': limite_inferior,
        'limite_superior': limite_superior
    }
    
    print(f"  Rango normal: [{limite_inferior:.2f}°C, {limite_superior:.2f}°C]")
    
    if len(outliers) > 0:
        print(f"  Outliers encontrados: {len(outliers)}")
        for j, (valor, dia) in enumerate(zip(outliers, dias_outliers)):
            print(f"    - Día {dia}: {valor:.2f}°C")
    else:
        print(f"  Outliers encontrados: 0")

print("\n" + "="*70)
print("RESUMEN COMPARATIVO")
print("="*70)

print("\nTemperatura media por ciudad:")
for ciudad in ciudades:
    print(f"  {ciudad}: {media_ciudades[ciudad]:.2f}°C")

print("\nCiudad con mayor temperatura media:", max(media_ciudades, key=media_ciudades.get))
print("Ciudad con menor temperatura media:", min(media_ciudades, key=media_ciudades.get))

